#!/system/bin/sh
#此脚本来自ClearBox模块，用于提供终端菜单UI
if [ ! "$(whoami)" = "root" ]; then
    echo " » 请授予root权限！"
    exit 1
fi
######
if [ ! -f "/data/adb/wipe_cache/PATH" ]; then
    echo " » Error：PATH读取错误！"
    exit 1
else
    source "/data/adb/wipe_cache/PATH"
fi
######
Version=$(grep "version=" "$home_dir/module.prop" | cut -f2 -d "=")
Str_1=$(grep "str=" "$home_dir/module.prop" | cut -f2 -d '=' | cut -f1 -d "|")
Str_2=$(grep "str=" "$home_dir/module.prop" | cut -f2 -d "|")
######
# 菜单函数
md_menu()
{
clear
echo -e "\033[104m [欢迎使用 ClearBox]\033[0m"
echo -e "\033[96m ==============================================\033[0m\n"
echo -e "\033[93m  1：一键优化清理 \t 2：自定义规则清理\033[0m\n"
echo -e "\033[93m  3：清除垃圾/空文件夹 \t 4：清空所有软件缓存\033[0m\n"
echo -e "\033[93m  5：磁铁（文件归类 \t 6：深度文件清理\033[0m\n"
echo -e "\033[93m  7：软件规则清理 \t 8：清空系统缓存\033[0m\n"
echo -e "\033[93m  9：自动清理 \t\t 10：阻止软件更新安装\033[0m\n"
echo -e "\033[93m  11：内部储存固定功能 \t 12：阻止缓存生成功能\033[0m\n"
echo -e "\033[93m  13：磁盘 & 软件优化 \t 00：模块管理\033[0m\n"
echo -e "\033[96m ==============================================\033[0m"
echo -e "\t\t\t   --- 键入 E、Q 退出 ---"
echo -n " 请输入相应序号: "
read input
case "$input" in
    1)
      clear
      "$home_dir/BashCore" ClearAll
      ;;
    2)
      clear
      "$home_dir/BashCore" List_Dir
      ;;
    3)
      clear
      "$home_dir/BashCore" All_Dir
      ;;
    4)
      clear
      "$home_dir/BashCore" ClearCache
      ;;
    5)
      echo -en " » 确认？(y): "
      read input_fa
      case "$input_fa" in
          y | Y)
            clear
            "$home_dir/BashCore" File_All
            ;;
          *)
            echo -e "\033[92m » 您选择了否！\033[0m"
            ;;
      esac
      ;;
    6)
      clear
      if [ -z "$(ls "$work_dir/文件格式配置/")" ]; then
          echo -e "\033[91m » 无文件格式配置！请尝试重装模块。\033[0m"
          return 1
      fi
      count=0
      echo -e "\n\033[104m [深度清理，请备份重要文档！！]\033[0m"
      echo -e "\033[96m ==============================================\033[0m\n"
      for file in "$work_dir/文件格式配置"/*; do
         filename=$(basename "$file" | cut -f1 -d ".")
         count=$((count + 1))
         Num[$count]="$count,$filename"
         echo -e "\033[93m\t $count：清理 $filename\033[0m\n"
      done
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -n " 请输入相应序号: "
      read fc_input
      count_2=0
      while true; do
         count_2=$((count_2 + 1))
         if [ "$(echo "${Num[$count_2]}" | cut -f1 -d ',')" = "$fc_input" ]; then
             filename=$(echo "${Num[$count_2]}" | cut -f2 -d ',')
             echo -en " » 确认？(y): "
             read fc_input_2
             case "$fc_input_2" in
                 y | Y)
                   clear
                   "$home_dir/BashCore" File_Clear "$filename"
                   break
                   ;;
                 *)
                   echo -e "\033[92m » 您选择了否！\033[0m"
                   break
                   ;;
             esac
         fi
         [ "$count_2" = "$count" ] && echo -e "\033[91m » 输入错误！\033[0m" && break
      done
      ;;
    7)
      clear
      if [ -z "$(ls "$work_dir/清理规则/")" ]; then
          echo -e "\033[91m » 无App清理配置！\033[0m"
          return 1
      fi
      count=0
      echo -e "\n\033[104m [软件清理，建议预检查配置文件]\033[0m"
      echo -e "\033[96m ==============================================\033[0m\n"
      for file in "$work_dir/清理规则"/*; do
         appname=$(cat "$file" | grep '@' | cut -f2 -d '/')
         count=$((count + 1))
         Num[$count]="$count,$appname"
         echo -e "\033[93m\t $count：清理 $appname\033[0m\n"
      done
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -n " 请输入相应序号: "
      read ac_input
      count_2=0
      while true; do
         count_2=$((count_2 + 1))
         if [ "$(echo "${Num[$count_2]}" | cut -f1 -d ',')" = "$ac_input" ]; then
             appname=$(echo "${Num[$count_2]}" | cut -f2 -d ',')
             clear
             "$home_dir/BashCore" Clear_App "$appname"
             break
         fi
         [ "$count_2" = "$count" ] && echo -e "\033[91m » 输入错误！\033[0m" && break
      done
      ;;
    8)
      echo -en " » 确认？(y): "
      read sc_input
      case "$sc_input" in
          y | Y)
            clear
            "$home_dir/BashCore" Clear_SCache
            ;;
          *)
            echo -e "\033[92m » 您选择了否！\033[0m"
            ;;
      esac
      ;;
    9)
