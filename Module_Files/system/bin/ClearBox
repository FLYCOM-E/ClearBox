            echo -e "\033[96m ==============================================\033[0m\n"
            echo -e "\033[93m \t1：自定义输入间隔时间（单位：分钟）\033[0m\n"
            echo -e "\033[93m \t0：关闭此功能\033[0m\n"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -n " 请输入相应序号:"
            read at_storage_input
            case "$at_storage_input" in
                1)
                  clear
                  echo -en " » 请输入纯数字，范围 60 分钟："
                  read minute_input
                  if ! echo "$minute_input" | grep [0-9] >>/dev/null; then
                      echo -e "\033[1;92m » 请输入纯数字！设置失败！！\033[0m"
                  elif [ "$minute_input" -lt 1 ]; then
                      echo -e "\033[1;92m » 间隔天数少于1分钟！设置失败！！\033[0m"
                  elif [ "$minute_input" -ge 60 ]; then
                      echo -e "\033[1;92m » 设置时间超过1小时！设置失败！！\033[0m"
                  else
                      echo -e "time=${minute_input}/M\ndate=0\nrun=$home_dir/BashCore All_Dir" > "$work_dir/TimedConfig/ClearDir.conf"
                      echo " » 设定成功！"
                  fi
                  ;;
                0)
                  clear
                  rm "$work_dir/TimedConfig/ClearDir.conf"
                  echo " » 已关闭！"
                  ;;
                *)
                  echo -e "\033[91m » 输入错误！\033[0m"
                  ;;
            esac
            ;;
          4)
            clear
            NowTime=$(grep "time=" "$work_dir/TimedConfig/ClearCache.conf" | cut -f2 -d "=")
            echo -e " \033[104m[设定时间    当前设置时间：$NowTime)]\033[0m"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -e "\033[93m \t1：自定义输入间隔时间（单位：天）\033[0m\n"
            echo -e "\033[93m \t0：关闭此功能\033[0m\n"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -n " 请输入相应序号:"
            read at_appclean_input
            case "$at_appclean_input" in
                1)
                  clear
                  echo -en " » 请输入纯数字，范围 1～30 天："
                  read day_input
                  if ! echo "$day_input" | grep [0-9] >>/dev/null; then
                      echo -e "\033[1;92m » 请输入纯数字！设置失败！！\033[0m"
                  elif [ "$day_input" -lt 1 ]; then
                      echo -e "\033[1;92m » 间隔天数少于1天！设置失败！！\033[0m"
                  elif [ "$day_input" -gt 30 ]; then
                      echo -e "\033[1;92m » 设置天数超过30天！设置失败！！\033[0m"
                  else
                      echo -e "time=${day_input}/D\ndate=0\nrun=$home_dir/BashCore ClearCache\nin=0/5" > "$work_dir/TimedConfig/ClearCache.conf"
                      echo " » 设定成功！"
                  fi
                  ;;
                0)
                  clear
                  rm "$work_dir/TimedConfig/ClearCache.conf"
                  echo " » 已关闭！"
                  ;;
                *)
                  echo -e "\033[91m » 输入错误！\033[0m"
                  ;;
            esac
            ;;
          5)
            clear
            NowTime=$(grep "time=" "$work_dir/TimedConfig/FileAll.conf" | cut -f2 -d "=")
            echo -e "\033[104m [设定时间    当前设置时间：$NowTime)]\033[0m"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -e "\033[93m \t1：自定义输入间隔时间（单位：小时）\033[0m\n"
            echo -e "\033[93m \t0：关闭此功能\033[0m\n"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -n " 请输入相应序号:"
            read at_fileall_input
            case "$at_fileall_input" in
                1)
                  clear
                  echo -en " » 请输入纯数字，范围 1～24 小时："
                  read hour_input
                  if ! echo "$hour_input" | grep [0-9] >>/dev/null; then
                      echo -e "\033[1;92m » 请输入纯数字！设置失败！！\033[0m"
                  elif [ "$hour_input" -lt 1 ]; then
                      echo -e "\033[1;92m » 间隔天数少于1小时！设置失败！！\033[0m"
                  elif [ "$hour_input" -ge 24 ]; then
                      echo -e "\033[1;92m » 设置时间超过24小时！设置失败！！\033[0m"
                  else
                      echo -e "time=${hour_input}/H\ndate=0\nrun=$home_dir/BashCore File_All" > "$work_dir/TimedConfig/FileAll.conf"
                      echo " » 设定成功！"
                  fi
                  ;;
                0)
                  clear
                  rm "$work_dir/TimedConfig/FileAll.conf"
                  echo " » 已关闭！"
                  ;;
                *)
                  echo -e "\033[91m » 输入错误！\033[0m"
                  ;;
            esac
            ;;
          *)
            echo -e "\033[91m » 输入错误！\033[0m"
            ;;
      esac
      ;;
    10)
      clear
      if [ "$clearbox_stop_install" = 1 ]; then
          text_1="关闭"
      else
          text_1="开启"
      fi
      echo -e "\033[104m [APP更新安装管理]\033[0m"
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -e "\033[93m \t1：$text_1阻止APP更新安装\033[0m\n"
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -n " 请输入相应序号:"
      read sa_input
      case "$sa_input" in
          1)
            if [ "$clearbox_stop_install" != 1 ]; then
                echo -en " » 确认？(y): "
                read ok_input
                case "$ok_input" in
                    y | Y)
                      clear
                      "$home_dir/BashCore" StopInstall STOP
                      ;;
                    *)
                      echo -e "\033[92m » 您选择了否！\033[0m"
                      ;;
                esac
            else
                clear
                "$home_dir/BashCore" StopInstall RESET
            fi
            ;;
          *)
            echo -e "\033[91m » 输入错误！\033[0m"
            ;;
      esac
      ;;
    11)
      clear
      if [ "$clearbox_stop_storage" = 1 ]; then
          text_1="关闭"
      else
          text_1="开启"
      fi
      echo -e "\033[104m [内部储存固定功能]\033[0m"
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -e "\033[93m \t1：$text_1固定内部储存\033[0m\n"
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -n " 请输入相应序号:"
      read ss_input
      case "$ss_input" in
          1)
            if [ "$clearbox_stop_storage" != 1 ]; then
                echo -en " » 确认？(y): "
                read ok_input
                case "$ok_input" in
                    y | Y)
                      clear
                      "$home_dir/BashCore" StopStorage STOP
                      ;;
                    *)
                      echo -e "\033[92m » 您选择了否！\033[0m"
                      ;;
                esac
            else
                clear
                "$home_dir/BashCore" StopStorage RESET
            fi
            ;;
          *)
            echo -e "\033[91m » 输入错误！\033[0m"
            ;;
      esac
      ;;
    12)
      clear
      if [ "$clearbox_stop_cache" = 1 ]; then
          text_1="关闭"
      else
          text_1="开启"
      fi
      echo -e "\033[104m [阻止缓存]\033[0m"
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -e "\033[93m \t1：$text_1阻止生成缓存功能\033[0m\n"
      echo -e "\033[93m \t2：软件加入白名单\033[0m\n"
      echo -e "\033[93m \t3：取消白名单软件\033[0m\n"
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -n " 请输入相应序号:"
      read sc_input
      case "$sc_input" in
          1)
            if [ "$clearbox_stop_cache" != 1 ]; then
                echo -en " » 确认？(y): "
                read ok_input
                case "$ok_input" in
                    y | Y)
                      clear
                      sed -i 's/clearbox_stop_cache=0/clearbox_stop_cache=1/g' "$work_dir/settings.prop"
                      echo " » 已开启，重启生效 ~"
                      ;;
                    *)
                      clear
                      echo -e "\033[92m » 您选择了否！\033[0m"
                      ;;
                esac
            else
                clear
                sed -i 's/clearbox_stop_cache=1/clearbox_stop_cache=0/g' "$work_dir/settings.prop"
                echo " » 已关闭，重启生效 ~"
            fi
            ;;
          2)
            clear
            echo -en " » 请输入软件包名（空格分隔）："
            read packages_input
            [ -z "$packages_input" ] && packages_input="null"
            for package in $packages_input; do
                if grep "$package\$" "$work_dir/whitelist.prop" >> /dev/null; then
                    echo " » $package 已存在白名单"
                    continue
                elif ! cmd package list package | grep "package:$package\$" >> /dev/null; then
                    echo " » $package 不在软件包列表! "
                    continue
                else
                    echo "$package" >> "$work_dir/whitelist.prop"
                    echo " » $package 已成功加入白名单!"
                fi
            done
            ;;
          3)
            clear
            echo -en " » 请输入软件包名（空格分隔）："
            read packages_input
            [ -z "$packages_input" ] && packages_input="null"
            for package in $packages_input; do
                if grep "$package\$" "$work_dir/whitelist.prop" >> /dev/null; then
                    sed -i /"$package"/d "$work_dir/whitelist.prop"
                    echo " $package 已成功从白名单移除！"
                else
                    echo " $package 不在白名单中！"
                fi
            done
            ;;
          *)
            echo -e "\033[91m » 输入错误！\033[0m"
            ;;
      esac
      ;;
    13)
      clear
      echo -e "\033[104m [磁盘 & 软件优化]\033[0m"
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -e "\033[93m \t1：磁盘 GC\033[0m\n"
      echo -e "\033[93m \t2：快速磁盘优化\033[0m\n"
      echo -e "\033[93m \t3：Dexoat 预编译\033[0m\n"
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -n " 请输入相应序号:"
      read dg_input
      case "$dg_input" in
          1)
            clear
            "$home_dir/BashCore" F2fs_GC
            ;;
          2)
            clear
            "$home_dir/BashCore" Fast_GC
            ;;
          3)
            clear
            echo -e "\033[104m [DEXOAT]\033[0m"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -e "\033[93m \t1：触发系统 Dexoat\033[0m\n"
            echo -e "\033[93m \t2：自定义模式全部编译\033[0m\n"
            echo -e "\033[93m \t3：恢复（RESET）\033[0m\n"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -n " 请输入相应序号:"
            read cust_mode
            case "$cust_mode" in
                1)
                  "$home_dir/BashCore" Dexoat_1
                  ;;
                2)
                  clear
                  echo -e "\033[104m [模式选择]\033[0m"
                  echo -e "\033[96m ==============================================\033[0m\n"
                  echo -e "\033[93m \t1：Speed 模式\033[0m\n"
                  echo -e "\033[93m \t2：Speed-Profile 模式\033[0m\n"
                  echo -e "\033[93m \t3：Everything 模式\033[0m\n"
                  echo -e "\033[96m ==============================================\033[0m\n"
                  echo -n " 请输入相应序号:"
                  read mode
                  case "$mode" in
                      1)
                        clear
                        "$home_dir/BashCore" Dexoat_2 speed
                        ;;
                      2)
                        clear
                        "$home_dir/BashCore" Dexoat_2 speed-profile
                        ;;
                      3)
                        clear
                        "$home_dir/BashCore" Dexoat_2 everything
                        ;;
                      *)
                        echo -e "\033[91m » 输入错误！\033[0m"
                        ;;
                  esac
                  ;;
                3)
                  "$home_dir/BashCore" Dexoat_3
                  ;;
                *)
                  echo -e "\033[91m » 输入错误！\033[0m"
                  ;;
            esac
            ;;
          *)
            echo -e "\033[91m » 输入错误！\033[0m"
            ;;
      esac
      ;;
    00)
      clear
      echo -e "\033[104m [模块管理菜单]\033[0m"
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -e "\033[93m \t0：立即生效当前配置（免重启）\033[0m\n"
      echo -e "\033[93m \t1：清理设置\033[0m\n"
      echo -e "\033[93m \t2：终端UI开关\033[0m\n"
      echo -e "\033[93m \t00：关于\033[0m\n"
      echo -e "\033[93m \t01：配置备份\033[0m\n"
      echo -e "\033[93m \t02：卸载模块（！\033[0m\n"
      echo -e "\033[93m \t03：查看日志\033[0m\n"
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -n " 请输入相应序号:"
      read settings_option_input
      case "$settings_option_input" in
          0)
            clear
            sh "$home_dir/service.sh"
            ;;
          1)
            clear
            if [ "$clearbox_auto_file_all" = 1 ]; then
                text_1="关闭"
            else
                text_1="开启"
            fi
            if [ "$clearbox_auto_fast_gc" = 1 ]; then
                text_2="关闭"
            else
                text_2="开启"
            fi
            echo -e "\033[104m [清理设置]\033[0m"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -e "\033[93m \t1：外部储存相关设置\033[0m\n"
            echo -e "\033[93m \t2：$text_1一键/定时自动清理时运行文件归类\033[0m\n"
            echo -e "\033[93m \t3：$text_2一键/定时自动清理时快速磁盘优化\033[0m\n"
            echo -e "\033[93m \t4：新增清理白名单\033[0m\n"
            echo -e "\033[93m \t5：取消白名单软件\033[0m\n"
            echo -e "\033[93m \t6：缓存清理跳过大小\033[0m\n"
            echo -e "\033[96m==============================================\033[0m\n"
            echo -n " 请输入相应序号:"
            read clean_option_input
            case "$clean_option_input" in
                1)
                  clear
                  if [ "$clearbox_clear_disk" = 1 ]; then
                      text_1="关闭"
                  else
                      text_1="开启"
                  fi
                  if [ "$clearbox_file_all_disk" = 1 ]; then
                      text_2="关闭"
                  else
                      text_2="开启"
                  fi
                  if [ "$clearbox_clear_disk" = 1 ]; then
                      text_3="关闭"
                  else
                      text_3="开启"
                  fi
                  echo -e "\033[104m [外部储存相关]\033[0m"
                  echo -e "\033[96m ==============================================\033[0m\n"
                  echo -e "\033[93m \t1：$text_1清理外部储存缓存\033[0m\n"
                  echo -e "\033[93m \t2：$text_2外部储存文件归类\033[0m\n"
                  echo -e "\033[93m \t3：$text_3外部储存文件清理\033[0m\n"
                  echo -e "\033[96m ==============================================\033[0m\n"
                  echo -n " 请输入相应序号:"
                  read disk_option_input
                  case "$disk_option_input" in
                      1)
                        if [ "$clearbox_clear_disk" != 1 ]; then
                            echo -en " » 确认？(y): "
                            read ok_input
                            case "$ok_input" in
                                y | Y)
                                  clear
                                  sed -i 's/clearbox_clear_disk=0/clearbox_clear_disk=1/g' "$work_dir/settings.prop"
                                  echo " » 已开启！"
                                  ;;
                                *)
                                  echo -e "\033[92m » 您选择了否！\033[0m"
                                  ;;
                            esac
                        else
                            clear
                            sed -i 's/clearbox_clear_disk=1/clearbox_clear_disk=0/g' "$work_dir/settings.prop"
                            echo " » 已关闭！"
                        fi
                        ;;
                      2)
                        if [ "$clearbox_file_all_disk" != 1 ]; then
                            echo -en " » 确认？(y): "
                            read ok_input
                            case "$ok_input" in
                                y | Y)
                                  clear
                                  sed -i 's/clearbox_file_all_disk=0/clearbox_file_all_disk=1/g' "$work_dir/settings.prop"
                                  echo " » 已开启！"
                                  ;;
                                *)
                                  echo -e "\033[92m » 您选择了否！\033[0m"
                                  ;;
                            esac
                        else
                            clear
                            sed -i 's/clearbox_file_all_disk=1/clearbox_file_all_disk=0/g' "$work_dir/settings.prop"
                            echo " » 已关闭！"
                        fi
                        ;;
                      3)
                        if [ "$clearbox_clear_disk" != 1 ]; then
                            echo -en " » 确认？(y): "
                            read ok_input
                            case "$ok_input" in
                                y | Y)
                                  clear
                                  sed -i 's/clearbox_file_clear_disk=0/clearbox_file_clear_disk=1/g' "$work_dir/settings.prop"
                                  echo " » 已开启！"
                                  ;;
                                *)
                                  echo -e "\033[92m » 您选择了否！\033[0m"
                                  ;;
                            esac
                        else
                            clear
                            sed -i 's/clearbox_file_clear_disk=1/clearbox_file_clear_disk=0/g' "$work_dir/settings.prop"
                            echo " » 已关闭！"
                        fi
                        ;;
                      *)
                        echo -e "\033[92m » 您选择了否！\033[0m"
                        ;;
                  esac
                  ;;
                2)
                  if [ "$clearbox_auto_file_all" != 1 ]; then
                      echo -en " » 确认？(y): "
                      read ok_input
                      case "$ok_input" in
                          y | Y)
                            clear
                            sed -i 's/clearbox_auto_file_all=0/clearbox_auto_file_all=1/g' "$work_dir/settings.prop"
                            echo " » 已开启！"
                            ;;
                          *)
                            echo -e "\033[92m » 您选择了否！\033[0m"
                            ;;
                      esac
                  else
                      clear
                      sed -i 's/clearbox_auto_file_all=1/clearbox_auto_file_all=0/g' "$work_dir/settings.prop"
                      echo " » 已关闭！"
                  fi
                  ;;
                3)
                  if [ "$clearbox_auto_fast_gc" != 1 ]; then
                      echo -en " » 确认？(y): "
                      read ok_input
                      case "$ok_input" in
                          y | Y)
                            clear
                            sed -i 's/clearbox_auto_fast_gc=0/clearbox_auto_fast_gc=1/g' "$work_dir/settings.prop"
                            echo " » 已开启！"
                            ;;
                          *)
                            echo -e "\033[92m » 您选择了否！\033[0m"
                            ;;
                      esac
                  else
                      clear
                      sed -i 's/clearbox_auto_fast_gc=1/clearbox_auto_fast_gc=0/g' "$work_dir/settings.prop"
                      echo " » 已关闭！"
                  fi
                  ;;
                4)
                  clear
                  echo -en " » 请输入软件包名（空格分隔）："
                  read packages_input
                  [ -z "$packages_input" ] && packages_input="null"
                  for package in $packages_input; do
                      if grep "$package\$" "$work_dir/ClearWhitelist.prop" >> /dev/null; then
                          echo " » $package 已存在白名单"
                          continue
                      elif ! cmd package list package | grep "package:$package\$" >> /dev/null; then
                          echo " » $package 不在软件包列表! "
                          continue
                      else
                          if cmd package list package -s | grep "package:$package\$" >> /dev/null; then
                              echo " » $package 无效. 请不要添加系统软件! "
                              continue
                          fi
                          echo "$package" >> "$work_dir/ClearWhitelist.prop"
                          echo " » $package 已成功加入白名单!"
                      fi
                  done
                  ;;
                5)
                  clear
                  echo -en " » 请输入软件包名（空格分隔）："
                  read packages_input
                  [ -z "$packages_input" ] && packages_input="null"
                  for package in $packages_input; do
                      if grep "$package\$" "$work_dir/ClearWhitelist.prop" >> /dev/null; then
                          sed -i /"$package"/d "$work_dir/ClearWhitelist.prop"
                          echo " $package 已成功从白名单中移除！"
                      else
                          echo " $package 不在白名单中！"
                      fi
                  done
                  ;;
                6)
                  clear
                  echo " » 当前最小大小为 $clearbox_clear_cache_size M"
                  echo -n " » 是否设置新值？(y/N):"
                  read ok_input
                  case "$ok_input" in
                      y | Y)
                        echo -n " » 请输入新值：(单位：兆（M）. 范围：100M):"
                        read size_input
                        if ! echo "$size_input" | grep [0-9] >>/dev/null; then
                            echo -e "\033[1;92m » 请输入纯数字！设置失败！！\033[0m"
                        elif [ "$size_input" -lt 1 ]; then
                            echo -e "\033[1;92m » 设置大小小于1兆！设置失败！！\033[0m"
                        elif [ "$size_input" -gt 100 ]; then
                            echo -e "\033[1;92m » 设置大小超过100兆！设置失败！！\033[0m"
                        else
                            sed -i 's/clearbox_clear_cache_size=[0-9]*/clearbox_clear_cache_size='"$size_input"'/g' "$work_dir/settings.prop"
                            echo " » 设定成功！"
                        fi
                        ;;
                      *)
                        echo -e "\033[92m » 您选择了否！\033[0m"
                        ;;
                  esac
                  ;;
                *)
                  echo -e "\033[91m » 输入错误！\033[0m"
                  ;;
              esac
              ;;
          2)
            clear
            if [ -f "$home_dir/skip_mount" ]; then
                echo -n " » 是否开启终端UI？您将可以在任意终端键入`ClearBox`命令进入该UI（y/N）:"
                read ok_input
                case "$ok_input" in
                    y | Y)
                      if rm "$home_dir/skip_mount" 2>/dev/null; then
                          echo " » 已开启，重启生效！"
                      else
                          echo " » 开启失败！！"
                      fi
                      ;;
                    *)
                      echo -e "\033[92m » 您选择了否！\033[0m"
                      ;;
                esac
            else
                echo -n " » 是否关闭终端UI？（y/N）:"
                read ok_input
                case "$ok_input" in
                    y | Y)
                      if touch "$home_dir/skip_mount" 2>/dev/null; then
                          echo " » 已关闭，重启生效！"
                      else
                          echo " » 关闭失败！"
                      fi
                      ;;
                    *)
                      echo -e "\033[92m » 您选择了否！\033[0m"
                      ;;
                esac
            fi
            ;;
          00)
            clear
            echo -e "\033[104m [关于 ClearBox     $Version]\033[0m"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -e "\033[92m     CCC  L     EEEEEE     A      RRRRR\033[0m"
            echo -e "\033[92m   C      L     E_____    A A     R    R\033[0m"
            echo -e "\033[92m   C      L     E        A AAA    R  R\033[0m"
            echo -e "\033[92m     CCC  LLLL  EEEEEE  A     A   R    R\033[0m\n\n"
            echo -e "\033[104m \t$Str_1\033[0m"
            echo -e "\033[104m \t\t$Str_2\033[0m\n"
            echo -e "\033[93m \t1：GitHub\033[0m\n"
            echo -e "\033[93m \t2：内测-YHChat\033[0m\n"
            echo -e "\033[93m \t3：内测-Telegram\033[0m\n"
            if [ "$clearbox_debug_mode" = 1 ]; then
                DebugTitle=$(echo -en "\033[91m 调试模式已打开 \033[0m")
                echo -e "\t\t\t\t$DebugTitle"
            fi
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -en " 请输入相应序号:"
            read abort_option_input
            case "$abort_option_input" in
                1)
                  if am start -a android.intent.action.VIEW -d "https://github.com/FLYCOM-E/ClearBox" >>/dev/null; then
                      echo " » 跳转成功！"
                  else
                      echo " » 跳转失败！"
                  fi
                  ;;
                2)
                  if am start -a android.intent.action.VIEW -d "https://yhfx.jwznb.com/share?key=yigOTedUjh62&ts=1747355950" >>/dev/null; then
                      echo " » 跳转成功！"
                  else
                      echo " » 跳转失败！"
                  fi
                  ;;
                3)
                  if am start -a android.intent.action.VIEW -d "https://t.me/clearboxmodule" >>/dev/null; then
                      echo " » 跳转成功！"
                  else
                      echo " » 跳转失败！"
                  fi
                  ;;
                *)
                  echo -e "\033[91m » 输入错误！\033[0m"
                  ;;
            esac
            ;;
          01)
            clear
            echo -e "\033[104m [配置管理]\033[0m"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -e "\033[93m \t1：备份\033[0m\n"
            echo -e "\033[93m \t2：恢复\033[0m\n"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -en " 请输入相应序号:"
            read backup_option_input
            case "$backup_option_input" in
                1)
                  clear
                  "$home_dir/BashCore" configManager backup
                  ;;
                2)
                  clear
                  echo -en " » 请输入配置文件完整路径: "
                  read configFile
                  "$home_dir/BashCore" configManager recovery "$configFile"
                  ;;
                *)
                  echo -e "\033[91m » 输入错误！\033[0m"
                  ;;
            esac
            ;;
          02)
            echo -en " » 确定完全卸载 ClearBox 并清理残留😉？(y/n): "
            read ok_input
            case "$ok_input" in
                y | Y)
                  sh "$home_dir/uninstall.sh"
                  echo " » Bye！"
                  clear && exit 0
                  ;;
                *)
                  echo -e "\033[92m » 您选择了否！\033[0m"
                  ;;
            esac
            ;;
          03)
            clear
            echo -e "\033[104m [日志]\033[0m"
            if [ -f "$work_dir/LOG.log" ]; then
                more "$work_dir/LOG.log"
            fi
            ;;
          *)
            echo -e "\033[91m » 输入错误！\033[0m"
            ;;
        esac
        ;;
    e | E | q | Q)
      clear
      echo " » Bye！欢迎再来❤️❤️"
      exit 0
      ;;
    *)
      echo -e "\033[92m » 已经是最后一层了呦，键入E或Q退出！\033[0m"
      ;;
esac
echo -en "\033[92m » 回车返回\033[0m"; read null
}

