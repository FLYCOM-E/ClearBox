      echo -e "\033[96m ==============================================\033[0m\n"
      echo -e "\033[93m \t1：定期运行 一键优化清理\033[0m\n"
      echo -e "\033[93m \t2：定期运行 清理/干掉自定义目录\033[0m\n"
      echo -e "\033[93m \t3：定期运行 清除垃圾文件及空文件夹\033[0m\n"
      echo -e "\033[93m \t4：定期运行 清空所有软件缓存\033[0m\n"
      echo -e "\033[93m \t5：定期运行 磁铁（一键归类文件\033[0m\n"
      echo -e "\033[96m ==============================================\033[0m\n"
      echo -n " 请输入相应序号:"
      read at_input
      case "$at_input" in
          1)
            clear
            NowTime=$(grep "time=" "$work_dir/TimedConfig/ClearAll.conf" | cut -f2 -d "=")
            echo -e " \033[104m[设定时间    当前设置时间：$NowTime)]\033[0m"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -e "\033[93m \t1：自定义输入间隔时间（单位：天）\033[0m\n"
            echo -e "\033[93m \t0：关闭此功能\033[0m\n"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -n " 请输入相应序号:"
            read at_fast_input
            case "$at_fast_input" in
                1)
                  clear
                  echo -en " » 请输入纯数字，范围 1～30 天："
                  read day_input
                  if ! echo "$day_input" | grep [0-9] >>/dev/null; then
                      echo -e "\033[1;92m » 请输入纯数字！设置失败！！\033[0m"
                  elif [ "$day_input" -lt 1 ]; then
                      echo -e "\033[1;92m » 间隔天数少于1天！设置失败！！\033[0m"
                  elif [ "$day_input" -gt 30 ]; then
                      echo -e "\033[1;92m » 设置天数超过30天！设置失败！！\033[0m"
                  else
                      echo -e "time=${day_input}/D\ndate=0\nrun=$home_dir/BashCore ClearAll\nin=0/5" > "$work_dir/TimedConfig/ClearAll.conf"
                      echo " » 设定成功！"
                  fi
                  ;;
                0)
                  clear
                  rm "$work_dir/TimedConfig/ClearAll.conf"
                  echo " » 已关闭！"
                  ;;
                *)
                  echo -e "\033[91m » 输入错误！\033[0m"
                  ;;
            esac
            ;;
          2)
            clear
            NowTime=$(grep "time=" "$work_dir/TimedConfig/ListDir.conf" | cut -f2 -d "=")
            echo -e "\033[104m [设定时间    当前设置时间：$NowTime)]\033[0m"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -e "\033[93m \t1：自定义输入间隔时间（单位：小时）\033[0m\n"
            echo -e "\033[93m \t0：关闭此功能\033[0m\n"
            echo -e "\033[96m ==============================================\033[0m\n"
            echo -n " 请输入相应序号:"
            read at_cust_input
            case "$at_cust_input" in
                1)
                  clear
                  echo -en " » 请输入纯数字，范围 1～24 小时："
                  read hour_input
                  if ! echo "$hour_input" | grep [0-9] >>/dev/null; then
                      echo -e "\033[1;92m » 请输入纯数字！设置失败！！\033[0m"
                  elif [ "$hour_input" -lt 1 ]; then
                      echo -e "\033[1;92m » 间隔天数少于1小时！设置失败！！\033[0m"
                  elif [ "$hour_input" -ge 24 ]; then
                      echo -e "\033[1;92m » 设置时间超过24小时！设置失败！！\033[0m"
                  else
                      echo -e "time=${hour_input}/H\ndate=0\nrun=$home_dir/BashCore List_Dir" > "$work_dir/TimedConfig/ListDir.conf"
                      echo " » 设定成功！"
                  fi
                  ;;
                0)
                  clear
                  rm "$work_dir/TimedConfig/ListDir.conf"
                  echo " » 已关闭！"
                  ;;
                *)
                  echo -e "\033[91m » 输入错误！\033[0m"
                  ;;
            esac
            ;;
          3)
            clear
            NowTime=$(grep "time=" "$work_dir/TimedConfig/ClearDir.conf" | cut -f2 -d "=")
