<?xml version="1.0" encoding="utf-8"?>
<!-- START -->
<group title=" ">
    <action interruptible="false">
        <title>Custom Interval Selection (Unit: Hours)</title>
        <summary sh="echo -n 'Current setting time: '; grep 'time=' $work_dir/$timed_config_dir/FileAll.conf | cut -f2 -d '='" />
        <param name="hour_num" max="23" min="1" title="Slide to select time (Unit: Hours)" type="seekbar" value="12" />
            <set>
            echo -e "time=${hour_num}/H\ndate=0\nrun=$home_dir/$core File_All" > "$work_dir/$timed_config_dir/FileAll.conf"
            echo " » Setting successful!"
            </set>
    </action>
</group>
<!-- END -->
<!-- START -->
<group title=" ">
    <action interruptible="false" auto-off="false" >
        <title>Disable this function</title>
            <set>
            rm "$work_dir/$timed_config_dir/FileAll.conf"
            echo " » Disabled!"
            </set>
    </action>
</group>
<!-- END -->