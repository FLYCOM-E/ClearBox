cat <<w
<?xml version="1.0" encoding="utf-8"?>
<!-- START -->
<group title=" ">
    <pages>
        <page title="模块管理" config-sh="cat Settings.xml" />
    </pages>
</group>
<!-- END -->
<!-- START -->
<group title=" ">
    <action interruptible="false" auto-off="false" id="001">
        <title>一键优化清理</title>
            <set>
            "$home_dir/$core" ClearAll
            </set>
    </action>
    <action interruptible="false" auto-off="false" id="002">
        <title>清理/干掉自定义目录</title>
            <set>
            "$home_dir/$core" List_Dir
            </set>
    </action>
    <action interruptible="false" auto-off="false" id="003">
        <title>清除垃圾文件及空文件夹</title>
            <set>
            "$home_dir/$core" All_Dir
            </set>
    </action>
    <action interruptible="false" auto-off="false" id="004">
        <title>清空所有软件缓存</title>
            <set>
            "$home_dir/$core" ClearCache
            </set>
    </action>
    <action warning="根据规则深度归类内/外部储存文件，储存目录：对应目录下 Document 文件夹下" interruptible="false" shell="default" auto-off="false" auto-finish="false" id="005">
        <title>磁铁（一键归类文件</title>
            <set>
            "$home_dir/$core" File_All
            </set>
    </action>
    <page
        config-sh="Print_FileClearXml.sh"
        desc="此页面通过读取清理配置文件动态构建"
        title="深度文件清理" />
    <page
        config-sh="Print_AppClearXml.sh"
        desc="此页面通过读取配置规则文件动态构建"
        title="软件规则清理" />
        <action shell="default" warning="清理系统运行时必要的缓存，适合在系统出现奇怪bug或大更改时使用，清理后系统会自动重建这些缓存，此操作并不能提升性能或有效降低储存占用，如果您不了解不建议随意使用。清理后建议重启" interruptible="false" auto-off="false" auto-finish="false" id="006">
            <title>清空系统缓存</title>
                <set>
                "$home_dir/$core" Clear_SCache
                </set>
        </action>
</group>
<!-- END -->
<!-- START -->
<group title=" ">
    <pages>
        <page title="自动清理" config-sh="cat Timed_ProSettings.xml" />
    </pages>
</group>
<!-- END -->
<!-- START -->
<group title=" ">
    <switch>
        <title>规则目录绑定（重定向</title>
            <get>
            if grep "clearbox_bind_path=1" "$work_dir/settings.prop" >/dev/null; then
                echo 1
            else
                echo 0
            fi
            </get>
            <set>
            if grep "clearbox_bind_path=0" "$work_dir/settings.prop" >/dev/null; then
                sed -i 's/clearbox_bind_path=0/clearbox_bind_path=1/g' "$work_dir/settings.prop"
                "$home_dir/$core" "BindPath" "MOUNT"
                echo " » 已开启 ~"
            else
                sed -i 's/clearbox_bind_path=1/clearbox_bind_path=0/g' "$work_dir/settings.prop"
                "$home_dir/$core" "BindPath" "UMOUNT"
                echo " » 已关闭 ~"
            fi
            </set>
    </switch>
</group>
<!-- END -->
<!-- START -->
<group title="">
    <switch>
        <title>内部储存固定功能</title>
            <get>
            if grep "clearbox_stop_storage=1" "$work_dir/settings.prop" >/dev/null; then
                echo 1
            else
                echo 0
            fi
            </get>
            <set>
            if grep "clearbox_stop_storage=0" "$work_dir/settings.prop" >/dev/null; then
                "$home_dir/$core" StopStorage STOP
            else
                "$home_dir/$core" StopStorage RESET
            fi
            </set>
    </switch>
</group>
<!-- END -->
<!-- START -->
<group title=" ">
    <pages>
        <page title="系统优化" config-sh="cat system_plus.xml" />
    </pages>
</group>
<!-- END -->
<!-- START -->
<group title="">
    <pages>
        <page title="特殊功能" config-sh="cat Other.xml" />
    </pages>
</group>
<!-- END -->
w
