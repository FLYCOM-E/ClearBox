cat <<w
<?xml version="1.0" encoding="utf-8"?>
<!-- START -->
<group title=" ">
    <pages>
        <page title="模組管理" config-sh="cat Settings.xml" />
    </pages>
</group>
<!-- END -->
<!-- START -->
<group title=" ">
    <action interruptible="false" auto-off="false" id="001">
        <title>一鍵優化清理</title>
            <set>
            "$home_dir/$core" "--clear-all"
            </set>
    </action>
    <action interruptible="false" auto-off="false" id="002">
        <title>清理/刪掉自訂目錄</title>
            <set>
            "$home_dir/$core" "--clear-storage-cust"
            </set>
    </action>
    <action interruptible="false" auto-off="false" id="003">
        <title>清除垃圾檔案及空資料夾</title>
            <set>
            "$home_dir/$core" "--clear-storage"
            </set>
    </action>
    <action interruptible="false" auto-off="false" id="004">
        <title>清空所有軟體快取</title>
            <set>
            "$home_dir/$core" "--clear-app-cache"
            </set>
    </action>
    <action warning="根據規則深度歸類內/外部儲存文件，儲存目錄：對應目錄下 Document 資料夾下" interruptible="false" shell="default" auto-off="false" auto-finish="false" id="005">
        <title>磁鐵（一鍵歸類文件</title>
            <set>
            "$home_dir/$core" "--file-sort"
            </set>
    </action>
    <page
        config-sh="Print_FileClearXml.sh"
        desc="此頁面通過讀取清理配置文件動態構建"
        title="深度檔案清理" />
    <page
        config-sh="Print_AppClearXml.sh"
        desc="此頁面透過讀取配置規則文件動態構建"
        title="軟件規則清理" />
        <action shell="default" warning="清理系統運行時必要的快取，適合在系統出現奇怪 bug 或大更改時使用，清理後系統會自動重建這些快取，此操作並不能提升效能或有效降低儲存佔用，如果您不了解不建議隨意使用。清理後建議重新啟動" auto-off="false" auto-finish="false" id="006">
            <title>清空系統快取</title>
                <set>
                "$home_dir/$core" "--clear-system-cache"
                </set>
        </action>
</group>
<!-- END -->
<!-- START -->
<group title=" ">
    <pages>
        <page title="自動清理" config-sh="cat Timed_ProSettings.xml" />
    </pages>
</group>
<!-- END -->
<!-- START -->
<group title=" ">
    <switch>
        <title>規則目錄綁定（重新導向</title>
            <get>
            if grep "clearbox_bind_path=1" "$work_dir/settings.prop" >/dev/null; then
                echo 1
            else
                echo 0
            fi
            </get>
            <set>
            if grep "clearbox_bind_path=0" "$work_dir/settings.prop" >/dev/null; then
                sed -i 's/clearbox_bind_path=0/clearbox_bind_path=1/g' "$work_dir/settings.prop"
                "$home_dir/$core" "--storage-bind-custom" "MOUNT"
                echo " » 已開啟 ~"
            else
                sed -i 's/clearbox_bind_path=1/clearbox_bind_path=0/g' "$work_dir/settings.prop"
                "$home_dir/$core" "--storage-bind-custom" "UMOUNT"
                echo " » 已關閉 ~"
            fi
            </set>
    </switch>
</group>
<!-- END -->
<!-- START -->
<group title="">
    <switch>
        <title>內部儲存固定功能</title>
            <get>
            if grep "clearbox_stop_storage=1" "$work_dir/settings.prop" >/dev/null; then
                echo 1
            else
                echo 0
            fi
            </get>
            <set>
            if grep "clearbox_stop_storage=0" "$work_dir/settings.prop" >/dev/null; then
                "$home_dir/$core" "--storage-lock" STOP
            else
                "$home_dir/$core" "--storage-lock" RESET
            fi
            </set>
    </switch>
</group>
<!-- END -->
<!-- START -->
<group title=" ">
    <pages>
        <page title="系統最佳化" config-sh="cat system_plus.xml" />
    </pages>
</group>
<!-- END -->
<!-- START -->
<group title="">
    <pages>
        <page title="特殊功能" config-sh="cat Other.xml" />
    </pages>
</group>
<!-- END -->
w
