<?xml version="1.0" encoding="utf-8"?>
<!-- START -->
<group title="配置备份">
    <action interruptible="false" auto-off="false">
        <title>备份</title>
            <set>
            "$home_dir/BashCore" configManager backup
            </set>
    </action>
</group>
<!-- END -->
<!-- START -->
<group title="配置恢复">
    <action>
        <title>恢复</title>
        <param name="config" label="文件选择" type="file" editable="true" />
            <set>
            "$home_dir/BashCore" configManager recovery "$config"
            </set>
    </action>
</group>
<!-- END -->