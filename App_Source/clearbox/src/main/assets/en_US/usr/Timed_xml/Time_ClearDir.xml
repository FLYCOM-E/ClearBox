<?xml version="1.0" encoding="utf-8"?>
<!-- START -->
<group title=" ">
    <action>
        <title>Custom Interval Selection (Unit: Minutes)</title>
        <summary sh="echo -n 'Current setting time: '; grep 'time=' $work_dir/TimedConfig/ClearDir.conf | cut -f2 -d '='" />
        <param name="minute_num" max="59" min="1" title="Slide to select time (Unit: Minutes)" type="seekbar" value="10" />
            <set>
            echo -e "time=${minute_num}/M\ndate=0\nrun=$home_dir/BashCore All_Dir" > "$work_dir/TimedConfig/ClearDir.conf"
            echo " » Setting successful!"
            </set>
    </action>
</group>
<!-- END -->
<!-- START -->
<group title=" ">
    <action interruptible="false" auto-off="false" >
        <title>Disable this function</title>
            <set>
            rm "$work_dir/TimedConfig/ClearDir.conf"
            echo " » Disabled!"
            </set>
    </action>
</group>
<!-- END -->