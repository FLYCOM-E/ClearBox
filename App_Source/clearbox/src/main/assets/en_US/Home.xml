cat <<w
<?xml version="1.0" encoding="utf-8"?>
<!-- START -->
<group title=" ">
    <pages>
        <page title="Module Management" config-sh="cat Settings.xml" />
    </pages>
</group>
<!-- END -->
<!-- START -->
<group title="Cleaning Function">
    <action interruptible="false" auto-off="false" id="001">
        <title>One-Click Optimization and Cleanup</title>
            <set>
            "$home_dir/$core" ClearAll
            </set>
    </action>
    <action interruptible="false" auto-off="false" id="002">
        <title>Clean up/remove custom directory</title>
            <set>
            "$home_dir/$core" List_Dir
            </set>
    </action>
    <action interruptible="false" auto-off="false" id="003">
        <title>Clear junk files and empty folders</title>
            <set>
            "$home_dir/$core" All_Dir
            </set>
    </action>
    <action interruptible="false" auto-off="false" id="004">
        <title>Clear all app cache</title>
            <set>
            "$home_dir/$core" ClearCache
            </set>
    </action>
    <action warning="Classify internal/external storage files according to the rules, storage directory: under the Document folder in the corresponding directory" shell="default" auto-off="false" auto-finish="false" id="005">
        <title>Magnet (One-Click File Organization)</title>
            <set>
            "$home_dir/$core" File_All
            </set>
    </action>
    <page
        config-sh="Print_FileClearXml.sh"
        desc="This page is dynamically constructed by reading the cleanup configuration file."
        title="Deep File Cleanup" />
    <page
        config-sh="Print_AppClearXml.sh"
        desc="This page is dynamically generated by reading the configuration rule file."
        title="Software Rules Cleanup" />
        <action shell="default" warning="Clears the caches necessary for the system to run, suitable for use when the system encounters strange bugs or undergoes major changes. After clearing, the system will automatically rebuild these caches. This operation does not improve performance or significantly reduce storage usage, so it is not recommended to use it casually if you are not familiar with it. A restart is recommended after clearing." interruptible="false" auto-off="false" auto-finish="false" id="006">
            <title>Clear system cache</title>
                <set>
                "$home_dir/$core" Clear_SCache
                </set>
        </action>
</group>
<!-- END -->
<!-- START -->
<group>
    <pages>
        <page title="Auto Clean" config-sh="cat Timed_ProSettings.xml" />
    </pages>
</group>
<!-- END -->
<!-- START -->
<group title="Block all software updates/installations">
    <switch>
        <title>Block all software updates/installations</title>
            <get>
            if grep "clearbox_stop_install=1" "$work_dir/settings.prop" >/dev/null; then
                echo 1
            else
                echo 0
            fi
            </get>
            <set>
            if grep "clearbox_stop_install=0" "$work_dir/settings.prop" >/dev/null; then
                "$home_dir/$core" StopInstall STOP
            else
                "$home_dir/$core" StopInstall RESET
            fi
            </set>
    </switch>
</group>
<!-- END -->
<!-- START -->
<group title="Internal storage fixed function">
    <switch>
        <title>Internal storage fixed function</title>
            <get>
            if grep "clearbox_stop_storage=1" "$work_dir/settings.prop" >/dev/null; then
                echo 1
            else
                echo 0
            fi
            </get>
            <set>
            if grep "clearbox_stop_storage=0" "$work_dir/settings.prop" >/dev/null; then
                "$home_dir/$core" StopStorage STOP
            else
                "$home_dir/$core" StopStorage RESET
            fi
            </set>
    </switch>
</group>
<!-- END -->
<!-- START -->
<group title="Disable caching">
    <switch>
        <title>Disable caching</title>
        <get>
        if grep "clearbox_stop_cache=1" "$work_dir/settings.prop" >/dev/null; then
            echo 1
        else
            echo 0
        fi
        </get>
        <set>
        if grep "clearbox_stop_cache=0" "$work_dir/settings.prop" >/dev/null; then
            sed -i 's/clearbox_stop_cache=0/clearbox_stop_cache=1/g' "$work_dir/settings.prop"
            echo " » Enabled, effective after restarting ~"
        else
            sed -i 's/clearbox_stop_cache=1/clearbox_stop_cache=0/g' "$work_dir/settings.prop"
            echo " » Closed, effective after restarting ~"
        fi
        </set>
    </switch>
    <action interruptible="false" auto-off="false" >
        <title>Add software to the whitelist</title>
            <set>
            sh add_StopCacheWhitelist.sh
            </set>
        <param name="Package" type="app" options-sh="cmd package list package | cut -f2 -d ':' | grep -vxFf $work_dir/whitelist.prop" />
    </action>
    <action interruptible="false" auto-off="false" >
        <title>Remove whitelist software</title>
            <set>
            sh rm_StopCacheWhitelist.sh
            </set>
        <param name="Package" type="app" options-sh="cat $work_dir/whitelist.prop" />
    </action>
</group>
<!-- END -->
<!-- START -->
<group title="Other functions (new">
    <pages>
        <page title="Disk &amp; Software Optimization" config-sh="cat GC_Dexoat.xml" />
    </pages>
</group>
<!-- END -->
w
