    <string name="power_hot_reboot_cmd">sync; am restart || kill $(pgrep system_server);</string>
    <string name="power_safemode_cmd">sync; setprop persist.sys.safemode 1; svc power reboot || reboot;</string>
    <string name="power_fastboot_cmd">sync; reboot bootloader;</string>
